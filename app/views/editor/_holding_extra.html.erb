<% if item.digital_objects.images.size > 0 %>
    <%= render :partial => "admin/digital_objects/digital_objects_embedded_panel", :locals => { :item => item } %>
<% end %>

<div id="source_preview_for_holding">
    <h2><%=I18n.t(:source_summary)%></h2>
    <%= render(partial: "marc/show", locals: {item: item.source, editor_profile: EditorConfiguration.get_show_layout(item.source), is_embedded: true } ) %>
</div>
